{
  "name": "mapguide",
  "version": "0.1.0",
  "description": "MapGuide — MapServer Mapfile & MapCache interactive editor",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "dev": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "electron:dev": "concurrently \"cd frontend && npm run dev\" \"wait-on http://127.0.0.1:18001 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build && electron-builder",
    "postinstall": "cd frontend && npm install"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "cross-env": "^7.0.3",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.mapguide.app",
    "productName": "MapGuide",
    "directories": {
      "output": "../dist",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend/dist",
        "to": "backend",
        "filter": ["**/*"]
      },
      {
        "from": "config",
        "to": "config",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
